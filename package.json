{
  "name": "alexleung.ca",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "prepare": "git config core.hooksPath .githooks || true",
    "image:variants": "node scripts/generate-image-variants.mjs",
    "image:variants:stage": "node scripts/generate-image-variants.mjs --staged --stage-generated",
    "prebuild": "yarn image:variants",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "docker compose run --rm -e PLAYWRIGHT_BASE_URL playwright-smoke",
    "test:e2e:visual": "docker compose run --rm -e PLAYWRIGHT_BASE_URL playwright-visual",
    "test:e2e:visual:update": "docker compose run --rm -e PLAYWRIGHT_BASE_URL playwright-update",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "perf:lighthouse": "lhci autorun --config=.lighthouserc.json",
    "lint": "eslint . && prettier --check '{src,docs,playwright,scripts,.github}/**/*.{js,jsx,ts,tsx,css,md,json,yml,mjs}' '*.{js,mjs,ts,json,md,yml}'",
    "lint:fix": "eslint --fix . && prettier --write '{src,docs,playwright,scripts,.github}/**/*.{js,jsx,ts,tsx,css,md,json,yml,mjs}' '*.{js,mjs,ts,json,md,yml}'",
    "predeploy": "yarn build",
    "deploy": "gh-pages -d out"
  },
  "dependencies": {
    "@next/third-parties": "^16.1.6",
    "feed": "^5.2.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-schemaorg": "^2.0.1",
    "rehype-sanitize": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.57.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gh-pages": "^6.3.0",
    "gray-matter": "^4.0.3",
    "hast-util-sanitize": "^5.0.2",
    "http-server": "^14.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "katex": "^0.16.38",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "schema-dts": "^1.1.5",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "glob@npm:^13.0.0": "npm:13.0.6",
    "minimatch@npm:^9.0.4": "npm:9.0.9",
    "minimatch@npm:^10.2.0": "npm:10.2.4",
    "tar@npm:^7.5.4": "npm:7.5.11"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
